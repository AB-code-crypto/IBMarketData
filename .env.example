TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-1000000000000
TELEGRAM_THREAD_ID_CONNECT=1
TELEGRAM_THREAD_ID_DEAL=2
TELEGRAM_THREAD_ID_DEAL_STATUS=3
TELEGRAM_THREAD_ID_ERROR=4

# TWS / IB Gateway endpoint used by this robot instance.
# Typical local TWS ports: 7497 for paper, 7496 for live.
# Multiple local TWS instances must use different API socket ports.
IB_HOST=127.0.0.1
IB_PORT=7497

# Base API client id for this robot. Internal services add their own offsets,
# so use a separate base range for every robot connected to the same TWS.
IB_CLIENT_ID=200

# Fail-closed guard: exact account that must be exposed by the selected TWS session.
IB_ACCOUNT_ID=U1234567
